                "type": "TASK",
                "name": "Rejected State",
                "x": 699,
                "y": 21
            },
            {
                "id": "p_split",
                "type": "GATEWAY",
                "name": "Parallel Split",
                "gateway_type": "PARALLEL_SPLIT",
                "x": 810,
                "y": 290
            },
            {
                "id": "t1",
                "type": "TASK",
                "name": "Task 1",
                "x": 1190,
                "y": 50
            },
            {
                "id": "t2",
                "type": "TASK",
                "name": "Task 2",
                "x": 1189,
                "y": 290
            },
            {
                "id": "p_join",
                "type": "GATEWAY",
