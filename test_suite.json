{
    "workflow": {
        "workflow_id": "test_flow_v2",
        "name": "Engine Verification Flow",
        "version": 2,
        "nodes": [
            {
                "id": "start",
                "type": "INTERNAL",
                "internal_type": "EVENT",
                "event_type": "START",
                "name": "Start Process",
                "x": 0,
                "y": 150
            },
            {
                "id": "task_init",
                "type": "TASK",
                "task_id": "init_task",
                "name": "Initialize Payload",
                "output_mapping": {
                    "ok": "ok"
                },
                "x": 150,
                "y": 150
            },
            {
                "id": "split",
                "type": "INTERNAL",
                "internal_type": "GATEWAY",
                "gateway_type": "EXCLUSIVE_SPLIT",
                "name": "Evaluation Gateway",
                "x": 300,
                "y": 150
            },
            {
                "id": "p_split",
                "type": "INTERNAL",
                "internal_type": "GATEWAY",
                "gateway_type": "PARALLEL_SPLIT",
                "name": "Parallel Split",
                "x": 450,
                "y": 50
            },
            {
                "id": "t1",
                "type": "TASK",
                "task_id": "parallel_task_1",
                "name": "Parallel Task 1",
                "x": 600,
                "y": 0
            },
            {
                "id": "t2",
                "type": "TASK",
                "task_id": "parallel_task_2",
                "name": "Parallel Task 2",
                "x": 600,
                "y": 100
            },
            {
                "id": "p_join",
                "type": "INTERNAL",
                "internal_type": "GATEWAY",
                "gateway_type": "PARALLEL_JOIN",
                "name": "Parallel Join",
                "x": 750,
                "y": 50
            },
            {
                "id": "alt_path",
                "type": "TASK",
                "task_id": "alt_task",
                "name": "Alternative Path",
                "x": 450,
                "y": 250
            },
            {
                "id": "e_join",
                "type": "INTERNAL",
                "internal_type": "GATEWAY",
                "gateway_type": "EXCLUSIVE_JOIN",
                "name": "Exclusive Join",
                "x": 900,
                "y": 150
            },
            {
                "id": "end",
                "type": "INTERNAL",
                "internal_type": "EVENT",
                "event_type": "END",
                "name": "End Process",
                "x": 1050,
                "y": 150
            }
        ],
        "edges": [
            {
                "id": "e_start",
                "source_id": "start",
                "target_id": "task_init"
            },
            {
                "id": "e_init",
                "source_id": "task_init",
                "target_id": "split"
            },
            {
                "id": "e_ok",
                "source_id": "split",
                "target_id": "p_split",
                "condition": "ok == true"
            },
            {
                "id": "e_fail",
                "source_id": "split",
                "target_id": "alt_path",
                "condition": "ok == false"
            },
            {
                "id": "e_p1",
                "source_id": "p_split",
                "target_id": "t1"
            },
            {
                "id": "e_p2",
                "source_id": "p_split",
                "target_id": "t2"
            },
            {
                "id": "e_j1",
                "source_id": "t1",
                "target_id": "p_join"
            },
            {
                "id": "e_j2",
                "source_id": "t2",
                "target_id": "p_join"
            },
            {
                "id": "e_pj_to_ej",
                "source_id": "p_join",
                "target_id": "e_join"
            },
            {
                "id": "e_alt_to_ej",
                "source_id": "alt_path",
                "target_id": "e_join"
            },
            {
                "id": "e_end",
                "source_id": "e_join",
                "target_id": "end"
            }
        ]
    },
    "scenarios": [
        {
            "name": "Scenario 1: Full Parallel Success Path",
            "steps": [
                {
                    "node_id": "task_init",
                    "results": {
                        "ok": true
                    }
                },
                {
                    "node_id": "t1",
                    "results": {}
                },
                {
                    "node_id": "t2",
                    "results": {}
                }
            ],
            "expected_tokens": [
                "end"
            ],
            "expected_status": "COMPLETED"
        },
        {
            "name": "Scenario 2: Alternative Rejection Path",
            "steps": [
                {
                    "node_id": "task_init",
                    "results": {
                        "ok": false
                    }
                },
                {
                    "node_id": "alt_path",
                    "results": {}
                }
            ],
            "expected_tokens": [
                "end"
            ],
            "expected_status": "COMPLETED"
        },
        {
            "name": "Scenario 3: Asynchronous Parallel Execution (Partial Join)",
            "steps": [
                {
                    "node_id": "task_init",
                    "results": {
                        "ok": true
                    }
                },
                {
                    "node_id": "t1",
                    "results": {}
                }
            ],
            "expected_tokens": [
                "t2",
                "p_join"
            ],
            "expected_status": "ACTIVE"
        },
        {
            "name": "Scenario 4: Immediate Parallel Split Initialization",
            "steps": [
                {
                    "node_id": "task_init",
                    "results": {
                        "ok": true
                    }
                }
            ],
            "expected_tokens": [
                "t1",
                "t2"
            ],
            "expected_status": "ACTIVE"
        },
        {
            "name": "Scenario 5: Reverse Partial Join (t2 completes first)",
            "steps": [
                {
                    "node_id": "task_init",
                    "results": {
                        "ok": true
                    }
                },
                {
                    "node_id": "t2",
                    "results": {}
                }
            ],
            "expected_tokens": [
                "t1",
                "p_join"
            ],
            "expected_status": "ACTIVE"
        }
    ]
}