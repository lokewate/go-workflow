            },
            {
                "id": "e2_fail",
                "source_id": "split",
                "target_id": "rejected",
                "condition": "payload.ok == false"
            },
            {
                "id": "e3",
                "source_id": "p_split",
                "target_id": "t1"
            },
            {
                "id": "e4",
                "source_id": "p_split",
                "target_id": "t2"
            },
            {
                "id": "e5",
                "source_id": "t1",
                "target_id": "p_join"
            },
            {
                "id": "e6",
                "source_id": "t2",
                "target_id": "p_join"
            },
            {
                "id": "e7",
                "source_id": "p_join",
                "target_id": "end"
            }
        ]
    },
    "scenarios": [
        {
            "name": "Scenario: Successful Approval and Parallel Join",
            "steps": [
                {
                    "node_id": "start",
                    "results": {
                        "passed": true
                    }
                },
                {
                    "node_id": "t1",
                    "results": {}
                },
                {
                    "node_id": "t2",
                    "results": {}
                }
            ],
            "expected_tokens": [
                "end"
            ],
            "expected_payload": {
                "ok": true
            }
        },
        {
            "name": "Scenario: Rejection Path (No Limbo)",
            "steps": [
                {
                    "node_id": "start",
                    "results": {
                        "passed": false
                    }
                }
            ],
            "expected_tokens": [
                "rejected"
            ],
            "expected_payload": {
                "ok": false
